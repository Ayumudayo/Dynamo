# Discord
DISCORD_TOKEN=your-discord-bot-token
DISCORD_REGISTER_GLOBALLY=false
DISCORD_DEV_GUILD_ID=123456789012345678
GUILD_ID=123456789012345678

# MongoDB
MONGODB_URI=mongodb+srv://username:password@dynamo-cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=dynamo-rs

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=4000
DASHBOARD_BASE_URL=http://127.0.0.1:4000
DISCORD_CLIENT_SECRET=your-discord-application-client-secret
# Optional: if omitted, the dashboard will auto-allow the bot application's owner.
DASHBOARD_ADMIN_USER_IDS=
# Optional: defaults to the legacy Dynamo invite permissions bitset.
DISCORD_BOT_INVITE_PERMISSIONS=2146958847

# Command Sync
DISCORD_COMMAND_SYNC_INTERVAL_SECONDS=15

# Logging
RUST_LOG=dynamo_bot=info,dynamo_dashboard=info,dynamo_app=info,dynamo_core=info,poise=info
