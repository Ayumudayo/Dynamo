# Discord
DISCORD_TOKEN=your-discord-bot-token
DISCORD_REGISTER_GLOBALLY=false
DISCORD_DEV_GUILD_ID=123456789012345678
GUILD_ID=123456789012345678

# MongoDB
MONGODB_URI=mongodb+srv://username:password@dynamo-cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=dynamo-rs

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3000

# Command Sync
DISCORD_COMMAND_SYNC_INTERVAL_SECONDS=15

# Optional First-Party Modules
DYNAMO_ENABLE_GIVEAWAY=false

# Logging
RUST_LOG=dynamo_bot=info,dynamo_dashboard=info,dynamo_app=info,dynamo_core=info,poise=info
