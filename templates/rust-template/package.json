{
  "name": "dynamo-rust-template",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright smoke tooling for the Dynamo Rust template dashboard",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dashboard:smoke:auth": "playwright codegen --save-storage=output/playwright/dashboard-auth.json http://127.0.0.1:3000/login",
    "dashboard:smoke": "playwright test -c playwright.dashboard.config.cjs tests/playwright/dashboard-guild-smoke.spec.cjs",
    "dashboard:smoke:headed": "playwright test --headed -c playwright.dashboard.config.cjs tests/playwright/dashboard-guild-smoke.spec.cjs",
    "dashboard:smoke:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
